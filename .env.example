# Freqtrade Trading Bot Environment Variables
# Copy this file to .env and fill in your actual values

# Binance API Credentials
# Get these from: https://www.binance.com/en/my/settings/api-management
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# Telegram Bot Credentials
# Get bot token from @BotFather: https://t.me/BotFather
# Get chat ID from: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# VPS Deployment (for manual deployment only)
# Not needed if using CircleCI automatic deployment
OVH_HOST=your_vps_ip_address
OVH_USER=root